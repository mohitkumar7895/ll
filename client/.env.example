# Local dev: use Vite proxy (recommended)
VITE_API_BASE_URL=/api

# Or point straight to backend (must add your frontend origin to server CORS)
# VITE_API_BASE_URL=http://localhost:5000/api

# Production — full API base including /api (also set this in Vercel → Environment Variables)
# VITE_API_BASE_URL=https://YOUR-SERVICE.onrender.com/api

# Optional: API origin only (no /api). Used if VITE_API_BASE_URL is missing at build time.
# VITE_PUBLIC_API_ORIGIN=https://YOUR-SERVICE.onrender.com
